{
  "name": "claude-code-coordination",
  "displayName": "Claude Code Coordination",
  "description": "Multi-terminal AI coordination for seamless development workflow",
  "version": "2.0.0",
  "publisher": "claude-coordination",
  "repository": {
    "type": "git",
    "url": "https://github.com/mandymgr/claude-code-coordination.git"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other",
    "Extension Packs"
  ],
  "keywords": [
    "ai",
    "claude",
    "coordination",
    "terminal",
    "collaboration",
    "magic"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:claude-coordination.coordinate",
    "workspaceContains:.claude-coordination"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claude-coordination.coordinate",
        "title": "Start Coordination Session",
        "category": "Claude Coordination",
        "icon": "$(sync)"
      },
      {
        "command": "claude-coordination.lockFile",
        "title": "Lock Current File",
        "category": "Claude Coordination",
        "icon": "$(lock)"
      },
      {
        "command": "claude-coordination.unlockFile",
        "title": "Unlock Current File",
        "category": "Claude Coordination",
        "icon": "$(unlock)"
      },
      {
        "command": "claude-coordination.status",
        "title": "Show Coordination Status",
        "category": "Claude Coordination",
        "icon": "$(info)"
      },
      {
        "command": "claude-coordination.sendMessage",
        "title": "Send Message to Team",
        "category": "Claude Coordination",
        "icon": "$(mail)"
      },
      {
        "command": "claude-coordination.aiAssist",
        "title": "Ask AI Assistant",
        "category": "Claude Coordination",
        "icon": "$(robot)"
      },
      {
        "command": "claude-coordination.openDashboard",
        "title": "Open Web Dashboard",
        "category": "Claude Coordination",
        "icon": "$(dashboard)"
      }
    ],
    "keybindings": [
      {
        "command": "claude-coordination.lockFile",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l",
        "when": "editorTextFocus"
      },
      {
        "command": "claude-coordination.aiAssist",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "editorTextFocus"
      },
      {
        "command": "claude-coordination.status",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "resourceScheme == file",
          "command": "claude-coordination.lockFile",
          "alt": "claude-coordination.unlockFile",
          "group": "claude-coordination@1"
        },
        {
          "when": "resourceScheme == file",
          "command": "claude-coordination.aiAssist",
          "group": "claude-coordination@2"
        }
      ],
      "explorer/context": [
        {
          "when": "resourceScheme == file",
          "command": "claude-coordination.lockFile",
          "group": "claude-coordination@1"
        }
      ],
      "commandPalette": [
        {
          "command": "claude-coordination.coordinate",
          "when": "workspaceFolder"
        },
        {
          "command": "claude-coordination.lockFile",
          "when": "editorIsOpen"
        },
        {
          "command": "claude-coordination.unlockFile",
          "when": "editorIsOpen"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "claude-coordination-status",
          "name": "Claude Coordination",
          "when": "workspaceFolder"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-coordination",
          "title": "Claude Coordination",
          "icon": "$(sync)"
        }
      ]
    },
    "configuration": {
      "title": "Claude Code Coordination",
      "properties": {
        "claude-coordination.autoStartSession": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start coordination session when opening workspace"
        },
        "claude-coordination.showFileDecorations": {
          "type": "boolean",
          "default": true,
          "description": "Show visual indicators for locked files"
        },
        "claude-coordination.enableNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show notifications for coordination events"
        },
        "claude-coordination.magicCliPath": {
          "type": "string",
          "default": "magic",
          "description": "Path to magic CLI executable"
        },
        "claude-coordination.webDashboardPort": {
          "type": "number",
          "default": 3000,
          "description": "Port for web dashboard server"
        }
      }
    },
    "colors": [
      {
        "id": "claude-coordination.lockedFile",
        "description": "Color for locked files",
        "defaults": {
          "dark": "#ff6b6b",
          "light": "#e74c3c"
        }
      },
      {
        "id": "claude-coordination.activeSession",
        "description": "Color for active coordination session",
        "defaults": {
          "dark": "#4ecdc4",
          "light": "#1abc9c"
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "eslint": "^8.28.0",
    "typescript": "^4.9.4",
    "@vscode/test-electron": "^2.2.0"
  },
  "dependencies": {
    "ws": "^8.14.2",
    "chokidar": "^3.5.3"
  }
}