{
  "name": "claude-code-coordination",
  "version": "1.0.0",
  "description": "Complete coordination system for multiple Claude Code terminal instances",
  "main": "src/coordinator.js",
  "bin": {
    "claude-coord": "./bin/claude-coord.sh"
  },
  "scripts": {
    "build": "npm run lint && npm run test && npm run package",
    "package": "tar -czf dist/claude-code-coordination-v$(node -p \"require('./package.json').version\").tar.gz --exclude=node_modules --exclude=.git --exclude=dist .",
    "install": "./install.sh",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "lint": "shellcheck src/*.sh || echo '⚠️  Shellcheck not found - skipping lint'",
    "docs": "markdown-toc README.md",
    "clean": "rm -rf dist node_modules",
    "prepare": "mkdir -p dist"
  },
  "keywords": [
    "claude-code",
    "coordination",
    "terminal",
    "collaboration",
    "file-locking",
    "session-management"
  ],
  "author": "Claude Code Community",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anthropics/claude-code-coordination.git"
  },
  "bugs": {
    "url": "https://github.com/anthropics/claude-code-coordination/issues"
  },
  "homepage": "https://github.com/anthropics/claude-code-coordination#readme",
  "dependencies": {},
  "devDependencies": {
    "jest": "^29.0.0",
    "markdown-toc": "^1.2.0"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "preferGlobal": true
}