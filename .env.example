# Claude Code Coordination - Environment Configuration
# Copy this to .env and fill in your actual API keys and credentials

# Server Configuration
PORT=8080
NODE_ENV=development

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/claude_coordination

# Redis Configuration
REDIS_URL=redis://localhost:6379

# AI Service API Keys
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
GOOGLE_API_KEY=your_google_gemini_api_key_here

# Deployment Service Tokens
VERCEL_TOKEN=your_vercel_token_here
NETLIFY_AUTH_TOKEN=your_netlify_auth_token_here

# AWS Credentials (for S3/CloudFront deployment)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1

# JWT Secret for session management
JWT_SECRET=your_super_secret_jwt_key_here

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# AI API Configuration
AI_API_TIMEOUT=30000
AI_MAX_RETRIES=3
AI_RATE_LIMIT_WINDOW=60000

# Feature Flags
ENABLE_AI_CACHING=true
ENABLE_REAL_DEPLOYMENTS=true
ENABLE_MULTI_USER=true
ENABLE_PERFORMANCE_TRACKING=true

# Development Settings
DEBUG_AI_CALLS=false
MOCK_DEPLOYMENTS=false